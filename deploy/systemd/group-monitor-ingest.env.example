# deploy/systemd/group-monitor-ingest.env.example

# Feature flag (keep false until Supabase is ready)
SUPABASE_INGEST_ENABLED=false

# Supabase backend-only (service role). Do NOT use these on frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional config
LEADS_JSONL_PATH=/root/workspace-poc/data/leads.jsonl
INGEST_STATE_PATH=/root/workspace-poc/data/supabase_ingest_state.json
GROUP_MAP_PATH=/root/workspace-poc/data/group_url_to_id.json
SUPABASE_INGEST_BATCH_SIZE=25
SUPABASE_INGEST_POLL_MS=30000
