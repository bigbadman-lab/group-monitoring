# deploy/systemd/group-monitor-hourly-report.service
[Unit]
Description=Group Monitor - Telegram hourly report (Supabase)
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=/root/workspace-poc
Environment=NODE_ENV=production
EnvironmentFile=-/etc/default/group-monitor-hourly-report
ExecStart=/usr/bin/node /root/workspace-poc/workers/telegram_hourly_report.js

StandardOutput=journal
StandardError=journal
